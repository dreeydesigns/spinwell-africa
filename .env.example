# Public Sanity Content Lake configuration for the website.
VITE_SANITY_PROJECT_ID=your_project_id
VITE_SANITY_DATASET=production

# Never add a Sanity API token to this file or any VITE_ variable.
# Tokens belong only in the Sanity Studio/server environment.

# Google Places API (New) — server-only. Enable Places API (New), restrict this
# key to your deployment server, and add the business's Google Place ID.
GOOGLE_PLACES_API_KEY=your_google_places_api_key
GOOGLE_PLACE_ID=your_google_place_id
